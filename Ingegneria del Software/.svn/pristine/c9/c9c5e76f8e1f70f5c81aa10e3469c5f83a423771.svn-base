      <a href="/registration" class="w3-bar-item w3-button"><i class="fa fa-user"></i> REGISTRATI</a>
         {% endif %}

    </div>
    <!-- Hide right-floated links on small screens and replace them with a menu icon -->

    <a href="javascript:void(0)" class="w3-bar-item w3-button w3-right w3-hide-large w3-hide-medium" onclick="w3_open()">
      <i class="fa fa-bars"></i>
    </a>
  </div>
</div>




<div class="container">
  <div class="btn">
    <a href="#">Verifica Immagine</a>
    <input type="file" style="display: none;">
  </div>
  <div class="btn">
    <a href="#">Verifica Audio</a>
    <input type="file" style="display: none;">
  </div>
  <div class="btn">
    <a href="#">Verifica Video</a>
    <input type="file" style="display: none;">
  </div>

 {% if message %}
  <script>
    alert("{{ message }}");
  </script>
{% endif %}

<div class="verify-bar">
<form method="POST" action="{{ url_for('verificaDominio') }}">
  <input type="text" name="link" placeholder="Inserisci il link della notizia ---> https://www.corriere.it/notizia" required>
  <button type="submit">Verifica</button>
</form>
</div>

</div>

<script>




  // Funzione per gestire il clic sul bottone
  function handleButtonClick(input) {
  input.addEventListener('change', function() {
    var file = input.files[0];
    if (file) {
      // Calcola una percentuale casuale di veridicità
      var percentuale = Math.floor(Math.random() * 101); // Genera un numero casuale da 0 a 100

      // Mostra una finestra di popup con la percentuale di veridicità
      alert("Percentuale di veridicità del file: " + percentuale + "%");
    }
  });

  input.click(); // Apre il selettore del file
}

  // Aggiunge un gestore di eventi a tutti i bottoni
  var buttons = document.querySelectorAll('.btn');
  buttons.forEach(function(button) {
    var link = button.querySelector('a');
    var input = button.querySelector('input[type="file"]');
    link.onclick = function() {
      handleButtonClick(input);
    };
  });
</script>


